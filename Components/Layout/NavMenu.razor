@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Event Tracker</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column h-100">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="create">
                <span class="bi bi-calendar-plus" aria-hidden="true"></span> 
                Create New Event Type
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="log">
                <span class="bi bi-calendar-plus" aria-hidden="true"></span> 
                Log Event Instance
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="viewer" Match="NavLinkMatch.All">
                <i class="bi bi-calendar-event" aria-hidden="true"></i> 
                Viewer
            </NavLink>
        </div>

        <!-- Authentication Links -->
        <div class="mt-auto mb-3">
            <AuthorizeView>
                <Authorized>
                    <div class="nav-item px-3">
                        <!-- We use a form to securely post a logout request -->
                        <form action="/Account/Logout" method="post">
                            <AntiforgeryToken />
                            <button type="submit" class="nav-link btn btn-link w-100 text-start">
                                <span class="bi bi-box-arrow-left" aria-hidden="true"></span> 
                                Logout
                            </button>
                        </form>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="Account/Login">
                            <span class="bi bi-person-badge" aria-hidden="true"></span> 
                            Login
                        </NavLink>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>
</div>